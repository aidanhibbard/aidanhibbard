{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn-vue": {
      "type": "local",
      "command": ["npx", "-y", "shadcn-vue@latest", "mcp"],
      "enabled": true
    },
    "nuxt-docs": {
      "type": "remote",
      "url": "https://nuxt.com/mcp",
      "enabled": true
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "default": {
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "instructions": [".cursor/rules/skilld-activation.mdc"]
}
